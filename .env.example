# Storefront server
NODE_ENV=production
PORT=3000
ADMIN_BACKEND_URL=http://127.0.0.1:4100
ONLINE_TTL_SECONDS=45
ENABLE_SYSTEM_ACTIVATIONS=false
SYSTEM_ACTIVATIONS_PER_DAY=15
INCLUDE_LEGACY_PURCHASES=false
ALLOW_LEGACY_PURCHASE_EVENTS=false
SEED_DEMO_STATS=false
STRICT_BACKEND_STATS=true

# Telegram reviews (optional)
TELEGRAM_REVIEWS_CHANNEL=otzivigptishkashop
TELEGRAM_REVIEWS_CACHE_MS=600000
TELEGRAM_REVIEWS_SCAN_MAX_ID=600
TELEGRAM_REVIEWS_HINT_WINDOW=30
TELEGRAM_REVIEWS_TOP_STEP=20
TELEGRAM_REVIEWS_FETCH_TIMEOUT_MS=2500
TELEGRAM_REVIEWS_REFRESH_TIMEOUT_MS=9000

# Admin backend (if shared .env is used from repo root)
APP_URL=https://gptishka.shop
APP_BASE_URL=https://gptishka.shop
ADMIN_UI_URL=https://gptishka.shop/admin
ADMIN_UI_URLS=
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/gptishka_admin
JWT_ACCESS_SECRET=change_this_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_16_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
REFRESH_COOKIE_NAME=admin_refresh_token
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# Email / notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@gptishka.local
CUSTOMER_SESSION_COOKIE_NAME=customer_session
CUSTOMER_SESSION_TTL_DAYS=30
CUSTOMER_MAGIC_LINK_TTL_MINUTES=20
CUSTOMER_TELEGRAM_AUTH_TTL_MINUTES=10
ACCOUNT_NOTIFICATIONS_ENABLED=false
ACCOUNT_NOTIFY_SCAN_INTERVAL_MS=300000
ACCOUNT_NOTIFY_WINDOW_MINUTES=60
ACCOUNT_NOTIFY_MAX_ATTEMPTS=5
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_LINK_TOKEN_TTL_MINUTES=15
TELEGRAM_CHAT_ID=

# Payment gateways
PAYMENT_PROVIDER=gateway
ENOT_API_KEY=
ENOT_SHOP_ID=
ENOT_WEBHOOK_SECRET=
PAYMENT_SECRET=
PAYMENT_SHOP_ID=
WEBHOOK_SECRET=
PAYMENT_API_BASE_URL=https://api.enot.io
PAYMENT_CREATE_PATH=/invoice/create
PAYMENT_REFUND_PATH=/invoice/refund
PAYMENT_SUCCESS_URL=https://gptishka.shop/success.html
PAYMENT_FAIL_URL=https://gptishka.shop/fail.html
PAYMENT_WEBHOOK_URL=https://gptishka.shop/api/public/webhook/payment
PAYMENT_WEBHOOK_SIGNATURE_HEADER=x-api-sha256-signature
PAYMENT_WEBHOOK_IP_ALLOWLIST=

LAVA_SHOP_ID=
LAVA_SECRET_KEY=
LAVA_ADDITIONAL_SECRET=
LAVA_WEBHOOK_SECRET=
LAVA_API_BASE_URL=https://api.lava.ru
LAVA_CREATE_PATH=/business/invoice/create
LAVA_STATUS_PATH=/business/invoice/status
LAVA_WEBHOOK_URL=https://gptishka.shop/api/public/webhook/lava
LAVA_WEBHOOK_SIGNATURE_HEADER=authorization
LAVA_WEBHOOK_IP_ALLOWLIST=

# Activation
ACTIVATION_DEVICE_ID=web
ACTIVATION_TOKEN_ENCRYPTION_KEY=
ACTIVATION_STORED_TOKEN_TTL_HOURS=168

# VPN (3x-ui / VLESS Reality)
VPN_SERVER_ID=eu-1
VPN_3XUI_BASE_URL=
VPN_3XUI_USERNAME=
VPN_3XUI_PASSWORD=
VPN_3XUI_INBOUND_ID=0
VPN_3XUI_CLIENT_TOTAL_GB=0
VPN_TELEGRAM_LOOKUP_TOKEN=
VPN_AUTO_SEED_PRODUCTS=false
VPN_ACCESS_LINK_TEMPLATE=
VPN_VLESS_HOST=vpn.gptishka.shop
VPN_VLESS_PORT=443
VPN_VLESS_SNI=www.microsoft.com
VPN_VLESS_PBK=
VPN_VLESS_SID=
VPN_VLESS_FP=chrome
VPN_VLESS_PATH=
