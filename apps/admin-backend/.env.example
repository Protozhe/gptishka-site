NODE_ENV=production
PORT=4100
APP_URL=https://admin-api.gptishka.shop
ADMIN_UI_URL=https://gptishka.shop/admin
ADMIN_UI_URLS=
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/gptishka_admin

JWT_ACCESS_SECRET=change_this_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_16_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
REFRESH_COOKIE_NAME=admin_refresh_token
SESSION_SECRET=
JWT_SECRET=

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@gptishka.local
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PAYMENT_PROVIDER=gateway
ENOT_API_KEY=
ENOT_SHOP_ID=
ENOT_WEBHOOK_SECRET=
PAYMENT_SECRET=
PAYMENT_SHOP_ID=
WEBHOOK_SECRET=
PAYMENT_API_BASE_URL=https://api.enot.io
PAYMENT_CREATE_PATH=/invoice/create
PAYMENT_REFUND_PATH=/invoice/refund
PAYMENT_SUCCESS_URL=https://gptishka.shop/success.html
PAYMENT_FAIL_URL=https://gptishka.shop/fail.html
PAYMENT_WEBHOOK_URL=https://admin-api.gptishka.shop/api/public/webhook/payment
PAYMENT_WEBHOOK_SIGNATURE_HEADER=x-api-sha256-signature
PAYMENT_WEBHOOK_IP_ALLOWLIST=

LAVA_SHOP_ID=
LAVA_SECRET_KEY=
LAVA_ADDITIONAL_SECRET=
LAVA_WEBHOOK_SECRET=
LAVA_API_BASE_URL=https://api.lava.ru
LAVA_CREATE_PATH=/business/invoice/create
LAVA_STATUS_PATH=/business/invoice/status
LAVA_WEBHOOK_URL=https://admin-api.gptishka.shop/api/public/webhook/lava
LAVA_WEBHOOK_SIGNATURE_HEADER=authorization
LAVA_WEBHOOK_IP_ALLOWLIST=

STORAGE_DRIVER=local
ACTIVATION_DEVICE_ID=web
ACTIVATION_TOKEN_ENCRYPTION_KEY=
ACTIVATION_STORED_TOKEN_TTL_HOURS=168
