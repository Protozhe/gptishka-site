NODE_ENV=production
PORT=4100
APP_URL=https://gptishka.shop
APP_BASE_URL=https://gptishka.shop
ADMIN_UI_URL=https://gptishka.shop
ADMIN_UI_URLS=https://gptishka.shop,https://www.gptishka.shop
HOST=127.0.0.1

# Legacy compatibility aliases
FRONTEND_URL=https://gptishka.shop
API_URL=https://gptishka.shop
SESSION_SECRET=

DATABASE_URL=postgresql://user:password@127.0.0.1:5432/gptishka_admin?schema=public
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
REFRESH_COOKIE_NAME=admin_refresh_token
BCRYPT_ROUNDS=12

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=info@gptishka.shop
CUSTOMER_SESSION_COOKIE_NAME=customer_session
CUSTOMER_SESSION_TTL_DAYS=30
CUSTOMER_MAGIC_LINK_TTL_MINUTES=20
CUSTOMER_TELEGRAM_AUTH_TTL_MINUTES=10
ACCOUNT_NOTIFICATIONS_ENABLED=false
ACCOUNT_NOTIFY_SCAN_INTERVAL_MS=300000
ACCOUNT_NOTIFY_WINDOW_MINUTES=60
ACCOUNT_NOTIFY_MAX_ATTEMPTS=5
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_LINK_TOKEN_TTL_MINUTES=15

PAYMENT_PROVIDER=gateway
ENOT_API_KEY=
ENOT_SHOP_ID=
ENOT_WEBHOOK_SECRET=
PAYMENT_API_BASE_URL=https://api.enot.io
PAYMENT_CREATE_PATH=/invoice/create
PAYMENT_REFUND_PATH=/invoice/refund
PAYMENT_SUCCESS_URL=https://gptishka.shop/success.html
PAYMENT_FAIL_URL=https://gptishka.shop/fail.html
PAYMENT_WEBHOOK_URL=https://gptishka.shop/api/public/webhook/payment
PAYMENT_WEBHOOK_SIGNATURE_HEADER=x-api-sha256-signature
PAYMENT_WEBHOOK_IP_ALLOWLIST=

LAVA_SHOP_ID=
LAVA_SECRET_KEY=
LAVA_ADDITIONAL_SECRET=
LAVA_WEBHOOK_SECRET=
LAVA_API_BASE_URL=https://api.lava.ru
LAVA_CREATE_PATH=/business/invoice/create
LAVA_STATUS_PATH=/business/invoice/status
LAVA_WEBHOOK_URL=https://gptishka.shop/api/public/webhook/lava
LAVA_WEBHOOK_SIGNATURE_HEADER=authorization
LAVA_WEBHOOK_IP_ALLOWLIST=

STORAGE_DRIVER=local

# VPN (3x-ui / VLESS Reality)
VPN_SERVER_ID=eu-1
VPN_3XUI_BASE_URL=
VPN_3XUI_USERNAME=
VPN_3XUI_PASSWORD=
VPN_3XUI_INBOUND_ID=0
VPN_3XUI_CLIENT_TOTAL_GB=0
VPN_TELEGRAM_LOOKUP_TOKEN=
VPN_AUTO_SEED_PRODUCTS=false
VPN_ACCESS_LINK_TEMPLATE=
VPN_VLESS_HOST=vpn.gptishka.shop
VPN_VLESS_PORT=443
VPN_VLESS_SNI=www.microsoft.com
VPN_VLESS_PBK=
VPN_VLESS_SID=7a
VPN_VLESS_FP=chrome
VPN_VLESS_PATH=
