generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  OWNER
  ADMIN
  MANAGER
  SUPPORT
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum Currency {
  USD
  EUR
  RUB
  USDT
}

enum PaymentStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

enum PromoCodeKind {
  GENERAL
  REFERRAL
  ADS
}

enum DiscountType {
  FIXED
  PERCENT
}

enum PartnerEarningStatus {
  PENDING
  APPROVED
  PAID
  REVERSED
}

enum LicenseKeyStatus {
  available
  reserved
  used
  revoked
}

enum ProductVisualBackgroundType {
  solid
  gradient
  image
}

model Role {
  id        String   @id @default(cuid())
  code      RoleCode @unique
  name      String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  isActive      Boolean        @default(true)
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  licenseKeyAuditLogs LicenseKeyAuditLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([roleId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Product {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  titleEn     String         @default("")
  iconPngUrl  String         @default("")
  description String
  descriptionEn String       @default("")
  modalDescription String    @default("")
  modalDescriptionEn String  @default("")
  price       Decimal        @db.Decimal(12, 2)
  oldPrice    Decimal?       @db.Decimal(12, 2)
  activationVariants Json?   @map("activation_variants")
  currency    Currency       @default(USD)
  category    String
  tags        String[]
  stock       Int?
  isActive    Boolean        @default(true)
  isArchived  Boolean        @default(false)
  images      ProductImage[]
  visualConfig ProductVisualConfig?
  showcasePlacements ProductShowcasePlacement[]
  servicePagePlacements ServicePageProductPlacement[]
  orderItems  OrderItem[]
  licenseKeys LicenseKey[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([isActive])
  @@index([category])
  @@index([createdAt])
}

model ProductVisualConfig {
  id                 String                      @id @default(cuid())
  productId          String                      @unique
  product            Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cardTitle          String                      @default("")
  cardDescription    String                      @default("")
  imageUrl           String                      @default("")
  imageAlt           String                      @default("")
  hoverImageUrl      String                      @default("")
  hoverImageAlt      String                      @default("")
  backgroundType     ProductVisualBackgroundType @default(solid)
  backgroundColor    String                      @default("")
  backgroundGradient String                      @default("")
  buttonText         String                      @default("")
  buttonStyle        String                      @default("")
  isVisible          Boolean                     @default(true)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([isVisible])
  @@index([updatedAt])
}

model ProductShowcaseSection {
  id             String                     @id @default(cuid())
  slug           String                     @unique
  title          String
  description    String                     @default("")
  sortOrder      Int                        @default(100)
  isActive       Boolean                    @default(true)
  showOnHomepage Boolean                    @default(true)
  showInCatalog  Boolean                    @default(true)
  placements     ProductShowcasePlacement[]
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([isActive, sortOrder])
  @@index([showOnHomepage])
  @@index([showInCatalog])
}

model ProductShowcasePlacement {
  id        String                 @id @default(cuid())
  productId String
  product   Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  sectionId String
  section   ProductShowcaseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sortOrder Int                    @default(100)
  isActive  Boolean                @default(true)
  isPinned  Boolean                @default(false)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([productId, sectionId])
  @@index([productId])
  @@index([sectionId, isActive, sortOrder])
  @@index([isPinned])
}

model ServicePage {
  id                 String                        @id @default(cuid())
  slug               String                        @unique
  path               String                        @unique
  serviceKey         String                        @map("service_key")
  title              String
  titleEn            String                        @default("") @map("title_en")
  heroEyebrow        String                        @default("Тарифные планы") @map("hero_eyebrow")
  heroTitle          String                        @default("") @map("hero_title")
  heroDescription    String                        @default("") @map("hero_description")
  heroVideoUrl       String                        @default("") @map("hero_video_url")
  heroImageUrl       String                        @default("") @map("hero_image_url")
  heroLogoUrl        String                        @default("") @map("hero_logo_url")
  theme              String                        @default("custom")
  accentColor        String                        @default("#35f28f") @map("accent_color")
  accentGradient     String                        @default("") @map("accent_gradient")
  darkOverlay        String                        @default("") @map("dark_overlay")
  colorOverlay       String                        @default("") @map("color_overlay")
  constructorTitle   String                        @default("") @map("constructor_title")
  constructorDescription String                    @default("") @map("constructor_description")
  infoSections       Json?                         @map("info_sections")
  faqItems           Json?                         @map("faq_items")
  paymentCaptionLava String                        @default("СБП 0% и карты 3.2%") @map("payment_caption_lava")
  paymentCaptionEnot String                        @default("Карты 3.2% и СБП 0%") @map("payment_caption_enot")
  isActive           Boolean                       @default(true) @map("is_active")
  isIndexed          Boolean                       @default(true) @map("is_indexed")
  sortOrder          Int                           @default(100) @map("sort_order")
  placements         ServicePageProductPlacement[]
  createdAt          DateTime                      @default(now()) @map("created_at")
  updatedAt          DateTime                      @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@index([serviceKey])
  @@map("service_pages")
}

model ServicePageProductPlacement {
  id            String      @id @default(cuid())
  servicePageId String      @map("service_page_id")
  servicePage   ServicePage @relation(fields: [servicePageId], references: [id], onDelete: Cascade)
  productId     String      @map("product_id")
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder     Int         @default(100) @map("sort_order")
  isActive      Boolean     @default(true) @map("is_active")
  isPinned      Boolean     @default(false) @map("is_pinned")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@unique([servicePageId, productId])
  @@index([productId])
  @@index([servicePageId, isActive, sortOrder])
  @@index([isPinned])
  @@map("service_page_product_placements")
}

model VpnServer {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  countryCode String?  @map("country_code")
  city        String?
  hostname    String
  port        Int      @default(443)
  sni         String?
  fp          String?  @default("chrome")
  pbk         String?
  sid         String?
  path        String?  @default("/")
  accessType  String   @default("vless_reality") @map("access_type")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  sortOrder   Int      @default(100) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@index([isDefault])
  @@map("vpn_servers")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Order {
  id            String       @id @default(cuid())
  email         String
  status        OrderStatus  @default(PENDING)
  source        String       @default("site")
  botType       String?
  telegramUserId String?     @map("telegram_user_id")
  telegramUsername String?   @map("telegram_username")
  telegramChatId String?     @map("telegram_chat_id")
  telegramLastError String?  @map("telegram_last_error")
  redeemTokenHash String?    @map("redeem_token_hash")
  paymentMethod String?
  paymentId     String?
  orderDetails  Json?        @map("order_details")
  country       String?
  ip            String?
  subtotalAmount Decimal      @default(0) @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal      @db.Decimal(12, 2)
  currency      Currency     @default(USD)
  promoCodeId   String?
  promoCode     PromoCode?   @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  promoCodeSnapshot String?
  partnerId     String?
  partner       Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  payments      Payment[]
  licenseKeys   LicenseKey[]
  vpnAccesses   VpnAccess[]
  partnerEarning PartnerEarning?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  telegramBotEvents TelegramBotEvent[]

  @@index([status])
  @@index([source])
  @@index([botType])
  @@index([telegramUserId])
  @@index([source, botType])
  @@index([email])
  @@index([createdAt])
  @@index([paymentId])
  @@index([promoCodeId])
  @@index([partnerId])
}

model TelegramBotEvent {
  id               String   @id @default(cuid())
  botType          String   @map("bot_type")
  eventType        String   @map("event_type")
  source           String   @default("telegram")
  orderId          String?  @map("order_id")
  order            Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  telegramUserId   String?  @map("telegram_user_id")
  telegramUsername String?  @map("telegram_username")
  telegramChatId   String?  @map("telegram_chat_id")
  messageText      String?  @map("message_text")
  callbackData     String?  @map("callback_data")
  meta             Json?
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([botType, createdAt])
  @@index([eventType, createdAt])
  @@index([orderId])
  @@index([telegramUserId, createdAt])
  @@map("telegram_bot_events")
}

model Customer {
  id            String                   @id @default(cuid())
  email         String                   @unique
  locale        String                   @default("ru")
  timezone      String                   @default("Europe/Moscow")
  emailVerifiedAt DateTime?              @map("email_verified_at")
  sessions      CustomerSession[]
  magicLinks    CustomerMagicLinkToken[]
  telegramAuthTokens CustomerTelegramAuthToken[]
  telegramLink  TelegramLink?
  telegramLinkTokens TelegramLinkToken[]
  notificationPreference CustomerNotificationPreference?
  notificationEvents CustomerNotificationEvent[]
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  @@index([emailVerifiedAt])
  @@map("customers")
}

model TelegramLink {
  id               String    @id @default(cuid())
  customerId       String    @unique @map("customer_id")
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  telegramId       String    @map("telegram_id")
  telegramUsername String?   @map("telegram_username")
  firstName        String?   @map("first_name")
  linkedAt         DateTime  @default(now()) @map("linked_at")
  unlinkedAt       DateTime? @map("unlinked_at")
  isActive         Boolean   @default(true) @map("is_active")
  lastError        String?   @map("last_error")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([telegramId])
  @@index([isActive, telegramId])
  @@map("telegram_links")
}

model TelegramLinkToken {
  id         String    @id @default(cuid())
  customerId String    @map("customer_id")
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([customerId, expiresAt])
  @@index([expiresAt, consumedAt])
  @@map("telegram_link_tokens")
}

model CustomerTelegramAuthToken {
  id               String    @id @default(cuid())
  tokenHash        String    @unique @map("token_hash")
  customerId       String?   @map("customer_id")
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  telegramId       String?   @map("telegram_id")
  requestIp        String?   @map("request_ip")
  requestUserAgent String?   @map("request_user_agent")
  expiresAt        DateTime  @map("expires_at")
  approvedAt       DateTime? @map("approved_at")
  consumedAt       DateTime? @map("consumed_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([customerId, expiresAt])
  @@index([telegramId, expiresAt])
  @@index([expiresAt, approvedAt, consumedAt])
  @@map("customer_telegram_auth_tokens")
}

model CustomerSession {
  id          String    @id @default(cuid())
  customerId  String    @map("customer_id")
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @map("token_hash")
  userAgent   String?   @map("user_agent")
  ip          String?
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")

  @@index([customerId, expiresAt])
  @@index([expiresAt])
  @@map("customer_sessions")
}

model CustomerMagicLinkToken {
  id                String    @id @default(cuid())
  customerId        String    @map("customer_id")
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique @map("token_hash")
  nextPath          String?   @map("next_path")
  expiresAt         DateTime  @map("expires_at")
  consumedAt        DateTime? @map("consumed_at")
  consumedIp        String?   @map("consumed_ip")
  consumedUserAgent String?   @map("consumed_user_agent")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([customerId, expiresAt])
  @@index([expiresAt, consumedAt])
  @@map("customer_magic_link_tokens")
}

model CustomerNotificationPreference {
  id                       String    @id @default(cuid())
  customerId               String    @unique @map("customer_id")
  customer                 Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  emailEnabled             Boolean   @default(true) @map("email_enabled")
  reminder7d               Boolean   @default(true) @map("reminder_7d")
  reminder3d               Boolean   @default(true) @map("reminder_3d")
  reminder1d               Boolean   @default(true) @map("reminder_1d")
  reminderExpired          Boolean   @default(true) @map("reminder_expired")
  marketingEmailEnabled    Boolean   @default(false) @map("marketing_email_enabled")
  transactionalEmailEnabled Boolean  @default(true) @map("transactional_email_enabled")
  emailStatus              String    @default("active") @map("email_status")
  lastEmailSentAt          DateTime? @map("last_email_sent_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@index([emailStatus])
  @@map("customer_notification_preferences")
}

model CustomerNotificationEvent {
  id            String    @id @default(cuid())
  customerId    String    @map("customer_id")
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vpnAccessId   String?   @map("vpn_access_id")
  vpnAccess     VpnAccess? @relation(fields: [vpnAccessId], references: [id], onDelete: SetNull)
  type          String
  channel       String    @default("email")
  dedupeKey     String    @unique @map("dedupe_key")
  windowStart   DateTime? @map("window_start")
  windowEnd     DateTime? @map("window_end")
  status        String    @default("pending")
  sentAt        DateTime? @map("sent_at")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error")
  payload       Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([customerId, status, createdAt])
  @@index([vpnAccessId])
  @@index([type, status])
  @@index([status, createdAt])
  @@map("customer_notification_events")
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  productRaw String
  price      Decimal  @db.Decimal(12, 2)
  quantity   Int      @default(1)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      String
  providerRef   String?
  status        PaymentStatus @default(INITIATED)
  amount        Decimal       @db.Decimal(12, 2)
  currency      Currency      @default(USD)
  payload       Json?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([provider])
  @@index([status])
}

model PromoCode {
  id               String   @id @default(cuid())
  code             String   @unique
  kind             PromoCodeKind @default(GENERAL)
  discountType     DiscountType @default(PERCENT)
  discountValue    Decimal  @default(0) @db.Decimal(12, 2)
  ownerLabel       String?
  campaign         String?
  note             String?
  discountPercent  Int
  isActive         Boolean  @default(true)
  usageLimit       Int?
  usedCount        Int      @default(0)
  expiresAt        DateTime?
  partnerId        String? @unique
  partner          Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  orders           Order[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([kind])
  @@index([ownerLabel])
  @@index([campaign])
  @@index([partnerId])
}

model Partner {
  id            String   @id @default(cuid())
  name          String
  payoutPercent Decimal  @default(0) @db.Decimal(5, 2)
  promoCode     PromoCode?
  orders        Order[]
  earnings      PartnerEarning[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PartnerEarning {
  id               String               @id @default(cuid())
  orderId           String               @unique
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partnerId         String
  partner           Partner              @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  commissionRate    Decimal              @db.Decimal(5, 2)
  commissionAmount  Decimal              @db.Decimal(12, 2)
  status            PartnerEarningStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
}

model VpnAccess {
  id               String     @id @default(cuid())
  telegramId       String?    @map("telegram_id")
  email            String?
  orderId          String?    @map("order_id")
  order            Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  uuid             String     @unique
  accessLink       String     @map("access_link")
  plan             String
  source           String
  serverId         String     @default("eu-1") @map("server_id")
  trafficUsedBytes BigInt     @default(0) @map("traffic_used_bytes")
  expiresAt        DateTime   @map("expires_at")
  isActive         Boolean    @default(true) @map("is_active")
  disabledAt       DateTime?  @map("disabled_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  events           VpnEvent[]
  notificationEvents CustomerNotificationEvent[]

  @@index([telegramId])
  @@index([email])
  @@index([orderId])
  @@index([isActive, expiresAt])
  @@map("vpn_access")
}

model VpnEvent {
  id          String     @id @default(cuid())
  vpnAccessId String?    @map("vpn_access_id")
  vpnAccess   VpnAccess? @relation(fields: [vpnAccessId], references: [id], onDelete: SetNull)
  telegramId  String?    @map("telegram_id")
  eventType   String     @map("event_type")
  meta        Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([vpnAccessId])
  @@index([telegramId])
  @@index([eventType, createdAt])
  @@map("vpn_events")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entityType   String
  entityId     String
  action       String
  before       Json?
  after        Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}

model LicenseKey {
  id        String           @id @default(uuid())
  productKey String          @map("product_key")
  productId String?          @map("product_id")
  product   Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  keyValue  String           @unique @map("key_value")
  activationSiteUrl String   @default("") @map("activation_site_url")
  status    LicenseKeyStatus @default(available)
  orderId   String?          @map("order_id")
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  email     String?          // customer email for admin UI list, optional
  reservedAt DateTime?       @map("reserved_at")
  usedAt    DateTime?        @map("used_at")
  revokedAt DateTime?        @map("revoked_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt
  auditLogs LicenseKeyAuditLog[]

  @@index([productKey, status])
  @@index([productKey, activationSiteUrl, status])
  @@index([orderId])
  @@map("license_keys")
}

model LicenseKeyAuditLog {
  id        Int        @id @default(autoincrement())
  keyId     String?    @map("key_id")
  key       LicenseKey? @relation(fields: [keyId], references: [id], onDelete: SetNull)
  action    String
  userId    String?    @map("user_id")
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  meta      Json?
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([keyId])
  @@index([userId])
  @@index([createdAt])
  @@map("key_audit_log")
}
